# Database (Neon PostgreSQL)
# pgbouncer=true: connection pooling için (transaction modunda çalışır)
# DIRECT_URL: Prisma migrate için direkt bağlantı (pgbouncer bypass)
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth
AUTH_SECRET=""           # openssl rand -base64 32
NEXTAUTH_URL="https://kolayaidat.vercel.app"

# Email (SMTP) — Gmail örneği: App Password gerekir (2FA açıkken)
# Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="youremail@gmail.com"
SMTP_PASS=""

# UploadThing (https://uploadthing.com)
UPLOADTHING_TOKEN=""
